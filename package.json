{
  "name": "waggle",
  "private": true,
  "scripts": {
    "postinstall": "npm run generate:api",
    "generate:api": "npm run generate --workspace=@waggle/api-client",
    "build": "turbo run build --env-mode=loose",
    "dev": "turbo run dev --parallel --env-mode=loose",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "dotenv-cli": "^10.0.0",
    "prettier": "^3.6.0",
    "prettier-plugin-svelte": "^3.4.0",
    "turbo": "^2.5.6"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.0",
  "workspaces": [
    "apps/*",
    "apps/*/*",
    "packages/*",
    "packages/typescript/*"
  ]
}
